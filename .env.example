# Arbos configuration example
#
# How to use this file:
# 1. Choose exactly one main provider with PROVIDER=...
# 2. Choose exactly one fallback provider with FALLBACK_PROVIDER=...
# 3. Set the model that matches each chosen provider.
# 4. Fill only the credentials needed by the providers you actually use.


# ── Main provider ────────────────────────────────────────────────────────────
#
# Supported values:
#   codex
#   anthropic
#   openrouter
#   opencode
#   chutes
#
# Active example below:
PROVIDER=codex
CODEX_MODEL=gpt-5.3-codex
#
# Other main-provider examples:
# PROVIDER=anthropic
# CLAUDE_MODEL=claude-sonnet-4-6
#
# PROVIDER=openrouter
# CLAUDE_MODEL=stepfun/step-3.5-flash:free
#
# PROVIDER=opencode
# OPENCODE_MODEL=minimax-m2.5-free
#
# PROVIDER=chutes
# CLAUDE_MODEL=moonshotai/Kimi-K2.5-TEE


# ── Fallback provider ────────────────────────────────────────────────────────
#
# Supported values:
#   codex
#   anthropic
#   openrouter
#   opencode
#   chutes
#
# Active example below:
FALLBACK_PROVIDER=opencode
FALLBACK_MODEL=minimax-m2.5-free
#
# Other fallback examples:
# FALLBACK_PROVIDER=codex
# FALLBACK_MODEL=gpt-5.3-codex
#
# FALLBACK_PROVIDER=anthropic
# FALLBACK_MODEL=claude-sonnet-4-6
#
# FALLBACK_PROVIDER=openrouter
# FALLBACK_MODEL=stepfun/step-3.5-flash:free
#
# FALLBACK_PROVIDER=chutes
# FALLBACK_MODEL=moonshotai/Kimi-K2.5-TEE


# ── Provider auth / API keys ────────────────────────────────────────────────
#
# Codex:
#   Run once on the machine:
#   codex login
#   or:
#   codex login --device-auth
#   Uses: CODEX_MODEL
#
# Anthropic / Claude Code:
#   Run once on the machine:
#   claude login
#   Uses: CLAUDE_MODEL
#
# OpenRouter:
#   Uses: CLAUDE_MODEL or FALLBACK_MODEL
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
#
# OpenCode:
#   Uses: OPENCODE_MODEL or FALLBACK_MODEL
OPENCODE_API_KEY="YOUR_OPENCODE_API_KEY"
#OPENCODE_AUTOUPDATE=false
#OPENCODE_SNAPSHOT=false
#
# Chutes:
#   Uses: CLAUDE_MODEL or FALLBACK_MODEL
CHUTES_API_KEY="YOUR_CHUTES_API_KEY"


# ── Telegram bot ─────────────────────────────────────────────────────────────
TAU_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_OWNER_ID="YOUR_TELEGRAM_OWNER_ID"


# ── Auto-push ────────────────────────────────────────────────────────────────
AUTO_PUSH=true
# https://github.com/settings/personal-access-tokens
GITHUB_TOKEN="YOUR_GITHUB_TOKEN"
