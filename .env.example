# Arbos configuration example
#
# How to use this file:
# 1. Choose exactly one main provider with PROVIDER=...
# 2. Choose exactly one fallback provider with FALLBACK_PROVIDER=...
# 3. Set the model that matches each chosen provider.
# 4. Fill only the credentials needed by the providers you actually use.


# ── Main provider ────────────────────────────────────────────────────────────
#
# Supported values:
#   codex
#   anthropic
#   openrouter
#   opencode
#   cursor
#   chutes
#
# Active example below:
PROVIDER=codex
CODEX_MODEL=gpt-5.3-codex
#
# Other main-provider examples:
# PROVIDER=anthropic
# CLAUDE_MODEL=claude-sonnet-4-6
#
# PROVIDER=openrouter
# CLAUDE_MODEL=stepfun/step-3.5-flash:free
#
# PROVIDER=opencode
# OPENCODE_MODEL=minimax-m2.5-free
#
# PROVIDER=cursor
# CURSOR_MODEL=composer-2-fast
#
# PROVIDER=chutes
# CLAUDE_MODEL=moonshotai/Kimi-K2.5-TEE


# ── Fallback provider ────────────────────────────────────────────────────────
#
# Supported values:
#   codex
#   anthropic
#   openrouter
#   opencode
#   cursor
#   chutes
#
# Active example below:
FALLBACK_PROVIDER=opencode
FALLBACK_MODEL=minimax-m2.5-free
#
# Other fallback examples:
# FALLBACK_PROVIDER=codex
# FALLBACK_MODEL=gpt-5.3-codex
#
# FALLBACK_PROVIDER=anthropic
# FALLBACK_MODEL=claude-sonnet-4-6
#
# FALLBACK_PROVIDER=openrouter
# FALLBACK_MODEL=stepfun/step-3.5-flash:free
#
# FALLBACK_PROVIDER=cursor
# FALLBACK_MODEL=composer-2-fast    (run `agent --list-models` to see all options)
#
# FALLBACK_PROVIDER=chutes
# FALLBACK_MODEL=moonshotai/Kimi-K2.5-TEE


# ── Provider auth / API keys ────────────────────────────────────────────────
#
# Codex:
#   Run once on the machine:
#   codex login
#   or:
#   codex login --device-auth
#   Uses: CODEX_MODEL
#
# Anthropic / Claude Code:
#   Run once on the machine:
#   claude login
#   Uses: CLAUDE_MODEL
#
# OpenRouter:
#   Uses: CLAUDE_MODEL or FALLBACK_MODEL
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
#
# OpenCode:
#   Uses: OPENCODE_MODEL or FALLBACK_MODEL
OPENCODE_API_KEY="YOUR_OPENCODE_API_KEY"
#OPENCODE_AUTOUPDATE=false
#OPENCODE_SNAPSHOT=false
#
# Cursor:
#   No API key needed — uses Cursor's built-in auth (requires a Cursor subscription).
#   Install once:  curl https://cursor.com/install -fsS | bash
#   Authenticate:  agent login
#   Uses: CURSOR_MODEL (default: composer-2-fast). Run `agent --list-models` to see all options.
#   Optionally set CURSOR_API_KEY if you prefer key-based auth over browser login.
#CURSOR_MODEL=composer-2-fast
#CURSOR_API_KEY=
#
# Chutes:
#   Uses: CLAUDE_MODEL or FALLBACK_MODEL
CHUTES_API_KEY="YOUR_CHUTES_API_KEY"


# ── Bittensor Data Providers ───────────────────────────────────────────────────
#
# Taostats:
#   API for network statistics, block emissions, miner reports.
#   Get key: https://docs.taostats.io/docs/api
#TAOSTATS_API_KEY="tao-xxxxx:xxxxxxxx"
#
# Taomarketcap:
#   API for TAO token market data (price, volume, market cap).
#   Get key: https://api.taomarketcap.com/developer/documentation/
#TAOMARKETCAP_API_KEY="YOUR_TAOMARKETCAP_API_KEY"


# ── Telegram bot ─────────────────────────────────────────────────────────────
TAU_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
# Status pings (goal steps, “Restarted.” on boot) use chat_id.txt — first line must be the target chat id (often your
# private chat with the bot, or the workspace group). If boot logs sendMessage 400, check logs for telegram= description;
# after group → supergroup migration, re-fetch id (tools/telegram_chat_ids.py).
#TELEGRAM_RESTART_PING=false
TELEGRAM_OWNER_ID="YOUR_TELEGRAM_OWNER_ID"
# Optional: comma-separated user ids with full operator access (same as Discord guild-owner tooling).
#TELEGRAM_OWNER_IDS=123456789,987654321
# Optional: comma-separated chat IDs where any member can discuss with the bot via `/arbos …` (text / voice / media + caption).
# Use the **Discussion supergroup** ID if you have a Channel + comments (not the channel ID).
# For a plain supergroup, use that group’s ID. Owner-only commands (/goal, /restart, …) unchanged.
# Get ID: @RawDataBot, forward a message, or getUpdates after a test message.
#TELEGRAM_PUBLIC_CHAT_IDS=-1001234567890

# Optional: group/supergroup IDs (comma-separated) with an isolated workspace on disk — like one Discord channel per folder:
#   context/workspace/<chat_id>/goals/<index>/GOAL.md
# In Telegram forum supergroups, /goal creates a forum topic; goal <index> is the topic's message_thread_id.
# Members use `/arbos …` (or media with caption `/arbos …`); operators keep `/` commands and free-form text.
#TELEGRAM_WORKSPACE_GROUP_IDS=-1001234567890

# When true, the Ralph goal loop pauses after each completed step (success or failure).
# Resume with /start <index>. Public Telegram Q&A is already one agent run per message.
#GOAL_PAUSE_AFTER_EACH_STEP=true

# When TELEGRAM_PUBLIC_CHAT_IDS or TELEGRAM_WORKSPACE_GROUP_IDS is set and TAU_BOT_TOKEN is set,
# defaults to false: goal loops do not auto-run on boot (no extra Telegram noise until /start <n>).
# Set to true if you want goals.json "started" to apply on each restart without Telegram idle mode.
#GOALS_BACKGROUND_AUTORUN=true

# Set to stream live tool/status updates into one edited Telegram message ("thinking...").
# Default off: only the final answer is sent (one or more messages if >4096 chars).
#TELEGRAM_STREAMING_UPDATES=true

# When true, after a **successful** step the goal **stops** (started=false, thread exits): “réponse envoyée”,
# wait until you send /start <index> again (e.g. after a new Telegram instruction). Takes precedence over
# GOAL_PAUSE_AFTER_EACH_STEP on success. Failures still use backoff unless you also use PAUSE.
#GOAL_STOP_AFTER_SUCCESS=true

# When true, ensures goal #1 exists with mission text from GOAL_TELEGRAM_BITTENSOR.md (repo root).
# Use with /start 1 if you still use the Ralph loop; public Telegram Q&A uses its own prompt either way.
#TELEGRAM_QA_FIXED_GOAL=true


# ── Auto-push ────────────────────────────────────────────────────────────────
AUTO_PUSH=true
# https://github.com/settings/personal-access-tokens
GITHUB_TOKEN="YOUR_GITHUB_TOKEN"
